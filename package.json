{
  "name": "@starxmaker/sudoku.js",
  "version": "1.0.0",
  "description": "A Sudoku puzzle generator and solver — TypeScript wrapper with CJS, ESM, and browser builds.",
  "author": "starxmaker",
  "contributors": [
    {
      "name": "robatron",
      "url": "https://github.com/robatron/sudoku.js"
    }
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.ts"],
    "roots": ["<rootDir>/test"]
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sudoku",
    "puzzle",
    "generator",
    "solver",
    "typescript"
  ],
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^25.5.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
