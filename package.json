{
  "name": "@starxmaker/sudoku.js",
  "version": "1.0.2",
  "description": "A Sudoku puzzle generator and solver — TypeScript wrapper with CJS, ESM, and browser builds.",
  "author": {
    "name": "robatron",
    "url": "https://github.com/robatron/sudoku.js"
  },
  "contributors": [
    { "name": "Rob McGuire", "url": "https://github.com/robatron" },
    { "name": "Lars Bonczek", "url": "https://github.com/larsbonczek" },
    { "name": "Laurens", "url": "https://github.com/laurens-vrh" },
    { "name": "starxmaker", "url": "https://github.com/starxmaker" }
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:qunit": "qunit test/tests.js",
    "prepublishOnly": "npm run build"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "roots": [
      "<rootDir>/test"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sudoku",
    "puzzle",
    "generator",
    "solver",
    "typescript"
  ],
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^25.5.0",
    "jest": "^29.0.0",
    "qunit": "^2.25.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
